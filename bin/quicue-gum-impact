#!/usr/bin/env bash
# quicue-gum-impact - Pretty impact analysis
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TARGET="$1"
PATH_ARG="${2:-.}"

if [ -z "$TARGET" ]; then
    gum style --foreground 196 "Usage: quicue-gum impact <target> [path]"
    exit 1
fi

# Get data using quicue-viz-data helper (handles all repo types)
DATA=$("$SCRIPT_DIR/quicue-viz-data" "$PATH_ARG") || {
    echo "Error: Could not load infrastructure data from $PATH_ARG" >&2
    exit 1
}

TOTAL=$(echo "$DATA" | jq '.metrics.total // 0')

if [ "$TOTAL" -eq 0 ]; then
    echo "Error: No resources found in infrastructure graph" >&2
    exit 1
fi

# Find dependents of target
AFFECTED=$(echo "$DATA" | jq -r --arg t "$TARGET" '
    .nodes[] | select(.ancestors | index($t)) | .name
' 2>/dev/null | sort)

AFFECTED_COUNT=$(echo "$AFFECTED" | grep -c . || echo 0)
PCT=$((AFFECTED_COUNT * 100 / TOTAL))

# Color based on severity
if [ "$PCT" -gt 50 ]; then
    COLOR="196"  # Red
elif [ "$PCT" -gt 25 ]; then
    COLOR="220"  # Yellow
else
    COLOR="156"  # Green
fi

# Header
gum style --border double --padding "1 2" --border-foreground "$COLOR" \
    "$(gum style --foreground "$COLOR" --bold "Impact Analysis: $TARGET")"

echo ""

# Stats
gum join --horizontal \
    "$(gum style --border rounded --padding "0 2" --border-foreground "$COLOR" \
        "$(gum style --foreground "$COLOR" --bold "$AFFECTED_COUNT / $TOTAL")" \
        "$(gum style --foreground 245 "Affected")")" \
    "$(gum style --border rounded --padding "0 2" --border-foreground "$COLOR" \
        "$(gum style --foreground "$COLOR" --bold "$PCT%")" \
        "$(gum style --foreground 245 "Blast Radius")")"

echo ""

if [ "$AFFECTED_COUNT" -gt 0 ]; then
    gum style --foreground 245 "Affected resources:"
    echo "$AFFECTED" | while read -r name; do
        gum style --foreground "$COLOR" "  - $name"
    done
fi
